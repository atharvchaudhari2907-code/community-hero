# Local data mode runs with zero external credentials needed.
# Flip to true once you've filled in FIREBASE_SERVICE_ACCOUNT_JSON below.
USE_FIREBASE=false
SQLITE_PATH=community_hero.db

# Paste your real Firebase service account JSON (as a single line) here
# when you're ready to switch off local mode. Leave blank for now.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Paste your real Gemini API key here. Leave blank to use the transparent
# rule-based fallback classifier (the app works either way).
GEMINI_API_KEY=

# Optional: enables real driving-distance worker dispatch instead of
# straight-line distance. Leave blank to use the (correct, just simpler)
# haversine fallback.
GOOGLE_MAPS_API_KEY=

JWT_SECRET=dev-only-secret-change-me-before-prod-min-32-chars
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10
AI_PROCESSING_TIMEOUT_SECONDS=30
FRONTEND_ORIGIN=http://localhost:3000
